# Copy to .env for local development
# Copy to .env.production for production defaults (or set in Vercel dashboard)

# Site URL — used for sitemap, canonical URLs, JSON-LD schema
# Local: http://localhost:5173
# Production: https://n-s-guide.vercel.app (or your custom domain)
VITE_SITE_URL=http://localhost:5173
SITE_URL=http://localhost:5173

# Admin password for /admin (local only; optional in production)
VITE_ADMIN_SECRET=your-admin-password

# Referral URL for "Apply now" CTAs
VITE_REFERRAL_URL=https://ns.com/networkschooler/invite
REFERRAL_URL=https://ns.com/networkschooler/invite

# Show "Apply now" CTA on all FAQ pages (true/false)
VITE_SHOW_REFERRAL_CTA=true
